# RideBazzar Production Environment Variables
# Copy these to Railway dashboard Variables tab

# ============================================================================
# DATABASE CONFIGURATION (MySQL on Railway)
# ============================================================================
DB_HOST=mysql.railway.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=YOUR_MYSQL_PASSWORD_HERE
DB_NAME=railway

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://ridebazzar-xxxx.railway.app

# ============================================================================
# SECURITY (JWT Tokens)
# ============================================================================
JWT_SECRET=CHANGE_THIS_TO_RANDOM_SECRET_STRING_MIN_32_CHARACTERS_LONG
JWT_EXPIRES_IN=7d

# ============================================================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================================================
# Before using email, setup Gmail App Password:
# 1. Go to: https://myaccount.google.com/security
# 2. Enable 2-Step Verification (if not already)
# 3. Go to: https://myaccount.google.com/apppasswords
# 4. Select Mail + Windows Computer
# 5. Copy the 16-character password
# 6. Paste below
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ridebazzar797@gmail.com
SMTP_PASS=YOUR_16_CHAR_APP_PASSWORD_HERE

# ============================================================================
# PAYMENT GATEWAY (For future Razorpay integration)
# ============================================================================
PAYMENT_GATEWAY_URL=https://api.razorpay.com
PAYMENT_API_KEY=your_razorpay_key_here
PAYMENT_API_SECRET=your_razorpay_secret_here

# ============================================================================
# UPLOAD CONFIGURATION
# ============================================================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# ============================================================================
# HOW TO USE THIS FILE
# ============================================================================
# 1. Replace all "YOUR_..." values with actual values
# 2. DO NOT commit this to GitHub with real values
# 3. In Railway Dashboard:
#    - Click your service
#    - Go to "Variables" tab
#    - Add each variable one by one
#    - Values from this file go in "Value" column
# ============================================================================
